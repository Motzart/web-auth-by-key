# Сгенерируй: openssl rand -base64 32
SESSION_SECRET=your_secret_at_least_32_characters_long_here

# URL приложения (для WebAuthn origin check)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upstash Redis — подтягиваются автоматически при подключении Redis в админке Vercel
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# (старые имена KV_* тоже поддерживаются)

# Опционально: RP ID по умолчанию для миграции старых ключей
# DEFAULT_REGISTERED_RP_ID=localhost
